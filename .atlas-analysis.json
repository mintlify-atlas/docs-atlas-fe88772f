  "keyFeatures": [
    "Supabase authentication with email verification and password reset",
    "Digital content management (PDF, video, audio) with Cloudinary storage",
    "Secure payment processing via Stripe with webhook support",
    "Role-based access control (user and admin roles)",
    "Content purchase tracking and access control",
    "Category-based content organization",
    "File upload handling with multer and Cloudinary",
    "MongoDB data persistence with Mongoose ODM"
  ],
  "publicApiSurface": [
    "POST /api/auth/signup",
    "POST /api/auth/login",
    "POST /api/auth/admin/login",
    "GET /api/auth/profile",
    "POST /api/auth/password-reset/request",
    "POST /api/auth/password-reset/update",
    "POST /api/auth/email/verify",
    "POST /api/auth/email/resend",
    "GET /api/content",
    "GET /api/content/:contentId",
    "POST /api/content",
    "PUT /api/content/:contentId",
    "DELETE /api/content/:contentId",
    "GET /api/content/:contentId/access",
    "GET /api/content/user/purchases",
    "GET /api/categories",
    "GET /api/categories/:slug",
    "POST /api/categories",
    "PUT /api/categories/:categoryId",
    "DELETE /api/categories/:categoryId",
    "POST /api/payments/create-payment-intent",
    "GET /api/payments/status/:paymentIntentId",
    "POST /api/payments/webhook",
    "GET /api/payments/admin/all",
    "POST /api/payments/admin/refund/:purchaseId"
  ]
